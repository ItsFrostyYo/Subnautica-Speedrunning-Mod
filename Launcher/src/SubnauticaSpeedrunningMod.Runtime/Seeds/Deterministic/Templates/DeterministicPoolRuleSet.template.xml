<DeterministicPoolRuleSet Version="1">
  <RuleSetId>ranked-survival-pools-v1</RuleSetId>
  <Description>Example pooled deterministic rules for ranked survival.</Description>
  <Mode>RankedSurvivalSingleplayer</Mode>
  <Pools>
    <Pool>
      <PoolId>MountainsTechSite</PoolId>
      <Description>All controlled Mountains techsite fragment slots.</Description>
      <Selectors>
        <Selector>
          <SelectorId>mountains-techsite-fragments</SelectorId>
          <BiomeNames>
            <Biome>Mountains_TechSite</Biome>
            <Biome>Mountains_TechSite_Barrier</Biome>
            <Biome>Mountains_TechSite_Scatter</Biome>
          </BiomeNames>
          <SlotTypeNames>
            <SlotType>Fragment</SlotType>
          </SlotTypeNames>
          <PoolHints>
            <Hint>MountainsTechSite</Hint>
          </PoolHints>
          <MinWorldX>-99999</MinWorldX>
          <MaxWorldX>99999</MaxWorldX>
          <MinWorldY>-99999</MinWorldY>
          <MaxWorldY>99999</MaxWorldY>
          <MinWorldZ>-99999</MinWorldZ>
          <MaxWorldZ>99999</MaxWorldZ>
        </Selector>
      </Selectors>
      <Guaranteed>
        <Entry>
          <TechTypeName>MoonpoolFragment</TechTypeName>
          <MinCount>2</MinCount>
          <MaxCount>5</MaxCount>
          <Weight>1</Weight>
          <SpawnCountPerSlot>1</SpawnCountPerSlot>
          <Notes>Guarantee at least two Moonpool fragments in this pool.</Notes>
        </Entry>
      </Guaranteed>
      <Caps>
        <Entry>
          <TechTypeName>PrawnSuitPropulsionCannonArmFragment</TechTypeName>
          <MinCount>0</MinCount>
          <MaxCount>1</MaxCount>
          <Weight>0</Weight>
          <SpawnCountPerSlot>1</SpawnCountPerSlot>
          <Notes>Cap bad filler in this pool.</Notes>
        </Entry>
      </Caps>
      <Blocked>
        <Entry>
          <TechTypeName>NuclearReactorFragment</TechTypeName>
          <MinCount>0</MinCount>
          <MaxCount>0</MaxCount>
          <Weight>0</Weight>
          <SpawnCountPerSlot>1</SpawnCountPerSlot>
          <Notes>Remove this fragment from controlled ranked pool.</Notes>
        </Entry>
      </Blocked>
      <Filler>
        <Entry>
          <TechTypeName>CyclopsHullFragment</TechTypeName>
          <MinCount>0</MinCount>
          <MaxCount>4</MaxCount>
          <Weight>1</Weight>
          <SpawnCountPerSlot>1</SpawnCountPerSlot>
          <Notes>Allowed filler after guarantees are satisfied.</Notes>
        </Entry>
      </Filler>
    </Pool>
  </Pools>
</DeterministicPoolRuleSet>
